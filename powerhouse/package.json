{
  "name": "powerhouse",
  "version": "0.1.0",
  "private": true,
  "description": "PowerHouse — discipline, strength, and athleticism transformation platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @powerhouse/api",
    "dev:web": "npm run dev --workspace @powerhouse/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm-run-all --parallel start:api start:web",
    "start:api": "npm run start --workspace @powerhouse/api",
    "start:web": "npm run start --workspace @powerhouse/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate --workspace @powerhouse/prisma",
    "db:migrate": "npm run migrate --workspace @powerhouse/prisma",
    "db:push": "npm run push --workspace @powerhouse/prisma",
    "db:seed": "npm run seed --workspace @powerhouse/prisma",
    "db:studio": "npm run studio --workspace @powerhouse/prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "openai": "^6.37.0"
  }
}
