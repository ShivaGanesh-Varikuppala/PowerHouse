# ----------------------------------------------------------------
# PowerHouse environment configuration
# Copy to .env (and apps/web/.env.local for the Next.js dev server)
# ----------------------------------------------------------------

# Database
DATABASE_URL="postgresql://powerhouse:powerhouse@localhost:5432/powerhouse?schema=public"

# Server
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# AI Coach (OPTIONAL)
# If unset, the AI Coach panel becomes read-only and shows a graceful fallback.
# The rest of PowerHouse works without this key.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Web (Next.js public)
NEXT_PUBLIC_API_URL="http://localhost:4000"
